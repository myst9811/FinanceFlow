# Used by `npm test` (vitest). Points at a separate database so tests never
# touch dev data. Create it once with:
#   docker exec financeflow-db-1 createdb -U financeflow financeflow_test
#   DATABASE_URL="postgresql://financeflow:financeflow@localhost:5433/financeflow_test?schema=public" npx prisma migrate deploy
DATABASE_URL="postgresql://financeflow:financeflow@localhost:5433/financeflow_test?schema=public"
DIRECT_URL="postgresql://financeflow:financeflow@localhost:5433/financeflow_test?schema=public"
PORT=3001
JWT_SECRET=test-secret-do-not-use-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
