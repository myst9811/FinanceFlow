{
  "name": "financeflow",
  "private": true,
  "version": "1.0.0",
  "description": "Convenience scripts for running the FinanceFlow backend and frontend together",
  "scripts": {
    "install:all": "npm --prefix backend ci && npm --prefix frontend ci",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint"
  }
}
